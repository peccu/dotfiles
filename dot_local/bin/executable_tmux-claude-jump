#!/usr/bin/env bash

set -o pipefail
set -o nounset

# tmux-claude-jump: list tmux panes running Claude Code with their live status
# (captured from the pane contents, not the stale terminal title) and jump to the
# selected one with skim. Panes waiting for a response are sorted to the top.
# Auto-refreshes every 3 seconds via sk --listen / --remote IPC.

if ! command -v sk >/dev/null 2>&1; then
    echo "Error: sk (skim) is required" >&2
    exit 1
fi

if ! tmux list-sessions &>/dev/null; then
    echo "Error: no tmux server running" >&2
    exit 1
fi

# ANSI colors for skim (--ansi)
red=$'\033[31m'
yellow=$'\033[33m'
green=$'\033[32m'
dim=$'\033[2m'
reset=$'\033[0m'

build_list() {
    declare -A seen
    while IFS=$'\t' read -r pane_id loc wname cpath ccmd; do
        # Grouped sessions share the same panes; show each underlying pane once.
        [[ -n "${seen[$pane_id]:-}" ]] && continue
        seen[$pane_id]=1

        content=$(tmux capture-pane -p -t "$pane_id" 2>/dev/null) || continue

        # Is this pane actually running Claude Code? Detect by its UI chrome, with
        # a fallback on the version-like process name (e.g. "2.1.162").
        if ! grep -qE '\? for shortcuts|auto mode on|plan mode on|bypass permissions|esc to interrupt|Esc to cancel|Do you want to proceed|for agents' <<<"$content"; then
            [[ "$ccmd" =~ ^[0-9]+\.[0-9]+ ]] || continue
        fi

        # Classify the live state (priority: needs input > working > idle).
        # "Esc to cancel" covers tool-approval and nav menus (user must act).
        # Working detection uses spinner/timer text; "esc to interrupt" no longer
        # appears in Claude Code >= 2.x.
        if grep -qE 'Do you want to proceed|Enter to select|No, and tell Claude|❯ 1\.|[Ee]sc to cancel' <<<"$content"; then
            rank=0
            label="${red}⏳ needs input${reset}"
        elif grep -qE 'Considering|Thinking\.\.\.|[0-9]+s [·•]|Claude is using your computer' <<<"$content"; then
            rank=2
            label="${dim}⚙  working    ${reset}"
        else
            rank=1
            label="${green}✅ idle       ${reset}"
        fi

        short=${cpath/#$HOME/\~}
        # rank<TAB>display ; rank is stripped (cut -f2-) before display, used only for sort.
        printf '%d\t%-15s  %s  %-45s  %s%s%s\n' \
            "$rank" "$loc" "$label" "$short" "$yellow" "$wname" "$reset"
    done < <(
        tmux list-panes -a -F \
            '#{pane_id}'$'\t''#{session_name}:#{window_index}.#{pane_index}'$'\t''#{window_name}'$'\t''#{pane_current_path}'$'\t''#{pane_current_command}'
    )
}

sorted_list() {
    build_list | sort -t$'\t' -k1,1n | cut -f2-
}

# --list-only: just output the sorted list (called by the auto-refresh background process)
if [[ "${1:-}" == "--list-only" ]]; then
    sorted_list
    exit 0
fi

SOCKET="tmux-claude-jump-$$"
SCRIPT="$(realpath "$0")"
REFRESH_INTERVAL=15

# Background process: initial load after sk socket is ready, then periodic refresh
(
    sleep 0.3  # give sk time to open the listen socket
    while true; do
        echo "reload($SCRIPT --list-only)" | sk --remote "$SOCKET" 2>/dev/null || true
        sleep "$REFRESH_INTERVAL"
    done
) &
REFRESHER_PID=$!
trap 'kill "$REFRESHER_PID" 2>/dev/null; wait "$REFRESHER_PID" 2>/dev/null; true' EXIT

# Start sk immediately with empty list; list is injected via IPC once socket is ready
selection=$(
    sk --listen "$SOCKET" \
         --prompt="Claude> " \
         --no-sort --ansi \
         --header "auto-refresh ${REFRESH_INTERVAL}s" \
         < /dev/null
) || exit 0

[[ -z "$selection" ]] && exit 0

# First whitespace-delimited token is "session:window.pane".
target="${selection%% *}"
sess_win="${target%.*}"

if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$sess_win"
else
    tmux attach-session -t "${sess_win%%:*}"
fi
tmux select-window -t "$sess_win" 2>/dev/null || true
tmux select-pane -t "$target" 2>/dev/null || true
