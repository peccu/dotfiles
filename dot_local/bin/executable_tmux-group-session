#!/usr/bin/env bash

set -o errexit
set -o pipefail
set -o nounset

# tmux-group-session: create a grouped session (shared windows) from a picker.
# - lists sessions with the current one marked '*'
# - selecting a non-current session creates "<name>-2" (or -3, -4 ...) grouped with it
# - selecting the current session prompts to kill it

if ! command -v sk >/dev/null 2>&1; then
    echo "Error: sk (skim) is required" >&2
    exit 1
fi

if ! tmux list-sessions &>/dev/null; then
    echo "Error: no tmux server running" >&2
    exit 1
fi

current=$(tmux display-message -p '#S')

selection=$(
    tmux list-sessions -F '#S' \
    | awk -v cur="$current" '
        $0 == cur { print "*\t" $0; next }
                  { rest[NR] = " \t" $0 }
        END       { for (i = 1; i <= NR; i++) if (i in rest) print rest[i] }
    ' \
    | sk --prompt="group> " --header="* = current session" --no-sort --delimiter='\t' --with-nth=1,2
) || exit 0

# selection looks like: "<marker>\t<session name>"
target="${selection#*$'\t'}"
[[ -z "$target" ]] && exit 0

action="group"
if [[ "$target" == "$current" ]]; then
    action=$(
        printf '%s\n' \
            "group:  create grouped session of '$target'" \
            "kill:   kill '$target'" \
            "cancel: do nothing" \
        | sk --prompt="action> " --no-sort \
        | awk -F: '{print $1}'
    ) || exit 0
    [[ -z "$action" || "$action" == "cancel" ]] && exit 0
fi

case "$action" in
    kill)
        # escape to another session before killing self
        other=$(tmux list-sessions -F '#S' | grep -vx "$target" | head -1 || true)
        if [[ -n "$other" ]]; then
            tmux switch-client -t "$other"
        fi
        tmux kill-session -t "$target"
        ;;
    group)
        i=2
        new="${target}-${i}"
        while tmux has-session -t="$new" 2>/dev/null; do
            i=$((i + 1))
            new="${target}-${i}"
        done
        tmux new-session -d -s "$new" -t "$target"
        tmux switch-client -t "$new"
        ;;
esac
